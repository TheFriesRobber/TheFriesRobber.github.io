---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, postUrl, sortPosts, uniqueTerms } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  return uniqueTerms(posts, 'categories').map((category) => ({
    params: { category },
    props: { category, posts: posts.filter((post) => post.data.categories.includes(category)) }
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`Category: ${category}`} current="categories">
  <p class="eyebrow">Category</p>
  <h1 class="page-title">{category}</h1>
  <section class="post-list" aria-label={`Posts in ${category}`}>
    {posts.map((post) => (
      <article class="post-card">
        <h2><a href={postUrl(post)}>{post.data.title}</a></h2>
        <div class="meta">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span>{post.data.tags.join(' / ')}</span>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
