---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortPosts, uniqueTerms } from '../../lib/posts';

const posts = sortPosts(await getCollection('blog'));
const categories = uniqueTerms(posts, 'categories');
---

<BaseLayout title="Categories" current="categories">
  <p class="eyebrow">Categories</p>
  <h1 class="page-title">分类</h1>
  <div class="term-grid">
    {categories.map((category) => <a class="pill" href={`/categories/${encodeURIComponent(category)}/`}>{category}</a>)}
  </div>
</BaseLayout>
