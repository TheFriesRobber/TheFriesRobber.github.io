---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortPosts, uniqueTerms } from '../../lib/posts';

const posts = sortPosts(await getCollection('blog'));
const tags = uniqueTerms(posts, 'tags');
---

<BaseLayout title="Tags" current="tags">
  <p class="eyebrow">Tags</p>
  <h1 class="page-title">标签</h1>
  <div class="term-grid">
    {tags.map((tag) => <a class="pill" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
  </div>
</BaseLayout>
